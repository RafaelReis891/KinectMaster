--- !u!114 &418969884
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 418969878}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: c062a5cd222bc734885e8326c1941a33, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::FallingObjectsGame
  perguntas:
  - texto: "Dermatite At\xF3pica pode piorar por estresse emocional?"
    audio: {fileID: 8300000, guid: c3ae5301ce314e94696d5bf8cb117f1e, type: 3}
    respostaCorreta: 1
  - texto: "Dermatite At\xF3pica acontece apenas em crian\xE7as?"
    audio: {fileID: 8300000, guid: 3a1612b8e361b17469888d089d8dad58, type: 3}
    respostaCorreta: 0
  - texto: "Tomar banho muito quente pode agravar a Dermatite At\xF3pica?"
    audio: {fileID: 8300000, guid: 84094631519d1024fa240aa048c67c90, type: 3}
    respostaCorreta: 1
  - texto: "Hidradenite Supurativa \xE9 contagiosa?"
    audio: {fileID: 8300000, guid: d332190b6ce06694a985dcfbcd10c215, type: 3}
    respostaCorreta: 0
  - texto: Usar roupas muito apertadas pode piorar o desconforto da Hidradenite Supurativa?
    audio: {fileID: 8300000, guid: 531e6c6d7e4747242a899ec21be60213, type: 3}
    respostaCorreta: 1
  - texto: "Hidradenite Supurativa \xE9 causada por falta de higiene?"
    audio: {fileID: 8300000, guid: 5a969a055dd02bb47a1fe487dd51974c, type: 3}
    respostaCorreta: 0
  - texto: "Psor\xEDase pode aparecer no couro cabeludo e nas unhas?"
    audio: {fileID: 8300000, guid: 38114f7eddef5c64899bff8f875a915d, type: 3}
    respostaCorreta: 1
  - texto: "Toda pessoa com Psor\xEDase apresenta sintomas iguais"
    audio: {fileID: 8300000, guid: c1ac8b6e804e70d488e591fa5ad3def9, type: 3}
    respostaCorreta: 0
  - texto: "Psor\xEDase \xE9 transmitida pelo toque?"
    audio: {fileID: 8300000, guid: a3b9f8e4647783345ba52cbcaf007896, type: 3}
    respostaCorreta: 0
  - texto: "Voc\xEA vai passar a acompanhar o Instituto Espa\xE7o de Vida e participar
      de mais eventos conosco?"
    audio: {fileID: 8300000, guid: dce8b2c841db9914fb19192e04bd00ca, type: 3}
    respostaCorreta: 1
  perguntaLabel: {fileID: 1557411017}
  timerText: {fileID: 2036393291}
  scoreText: {fileID: 970776404}
  perguntaNumeroText: {fileID: 120210969}
